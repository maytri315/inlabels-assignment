# Required for Google cross-check
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# RSS feed to monitor (Lucknow examples or any city/brand feed)
NEWS_FEED_URL=https://news.google.com/rss/search?q=Lucknow&hl=en-IN&gl=IN&ceid=IN:en

# Optional tuning
OUTPUT_DIR=output
MAX_STORIES=4
LOOKBACK_HOURS=4
ROAST_STYLE=sharp
VOICE_LANG=en-US
EDGE_TTS_VOICE=en-US-AriaNeural
EDGE_TTS_RATE=+15%
POLLINATIONS_BASE_URL=https://image.pollinations.ai

# Optional: switch to ElevenLabs later
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Django backend options
DJANGO_SECRET_KEY=dev-only-secret-key
DJANGO_DEBUG=1
